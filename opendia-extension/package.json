{
  "name": "opendia-extension",
  "version": "1.4.0",
  "description": "OpenDia + Cebian merged extension — MCP browser automation with agentic sidepanel",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:chrome": "wxt build --browser chrome",
    "build:firefox": "wxt build --browser firefox --mv2",
    "dev": "wxt",
    "dev:chrome": "wxt --browser chrome",
    "dev:firefox": "wxt --browser firefox --mv2",
    "package:chrome": "wxt zip --browser chrome",
    "package:firefox": "wxt zip --browser firefox --mv2",
    "postinstall": "wxt prepare",
    "build:legacy": "node build.js",
    "compile": "tsc --noEmit",
    "test:baseline": "node scripts/opendia-back-to-back.mjs",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "webextension",
    "mcp",
    "browser-automation",
    "cebian"
  ],
  "author": "Aaron J Mars",
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@lezer/highlight": "^1.2.3",
    "@mcp-ui/client": "^7.1.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@wxt-dev/i18n": "^0.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "dexie": "^4.4.4",
    "fflate": "^0.8.3",
    "front-matter": "^4.0.2",
    "lucide-react": "^1.22.0",
    "pdfjs-dist": "^6.1.200",
    "picomatch": "^4.0.4",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-arborist": "^3.12.0",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "tw-animate-css": "^1.4.0",
    "typebox": "1.1.38",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/chrome": "^0.2.0",
    "@types/isomorphic-git__lightning-fs": "^4.4.8",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@webext-core/fake-browser": "^1.5.2",
    "@wxt-dev/module-react": "^1.1.5",
    "fs-extra": "^11.3.5",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "web-ext": "^10.4.0",
    "wxt": "^0.20.27"
  }
}
